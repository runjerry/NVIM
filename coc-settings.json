{
  // python config
  "python.jediEnabled": false,
  "python.linting.enabled": true,
  "python.linting.pylintEnabled": true,
  "python.linting.pylintArgs": 
  [
      "--errors-only",
      "--generated-members=numpy.* ,torch.* ,cv2.* , cv.*"
  ],

  "snippets.ultisnips.directories":
  [
      "UltiSnips",
      "~/.config/nvim/utils/snips"
  ]

}
